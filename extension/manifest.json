{
  "manifest_version": 3,
  "name": "x402 Detector",
  "version": "1.0.0",
  "description": "Detects x402 payment-required endpoints while you browse. When a site charges with crypto, the icon lights up. Discover the full x402 agent directory at a2alist.ai.",
  "permissions": [
    "activeTab",
    "storage",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "x402 Detector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
