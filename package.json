{
  "name": "x402-validate",
  "version": "1.1.8",
  "description": "CLI + library to check if URLs support the x402 HTTP payment protocol. Validates schema, checks facilitator reachability, and outputs colored results.",
  "keywords": [
    "x402",
    "payment",
    "http402",
    "coinbase",
    "crypto",
    "paywall",
    "cli",
    "validator",
    "blockchain",
    "web3"
  ],
  "author": "a2alist.ai",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "x402-validate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suryast/x402-check"
  },
  "homepage": "https://github.com/suryast/x402-check#readme",
  "bugs": {
    "url": "https://github.com/suryast/x402-check/issues"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/srvzt"
  }
}
